---
import AnimeCard from "@/components/anime/AnimeCard.astro";
import CatalogStatus from "@/components/common/CatalogStatus.astro";
import ErrorState from "@/components/common/ErrorState.astro";
import MockNotice from "@/components/common/MockNotice.astro";
import PosterImage from "@/components/common/PosterImage.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getDataProvider, shouldRequireApiData } from "@/data/provider";
import { loadHomePageData } from "@/data/page-data";
import { buildWebsiteJsonLd } from "@/utils/seo";

const provider = getDataProvider();
const data = await loadHomePageData(
  provider,
  import.meta.env.PUBLIC_DEFAULT_SEASON ?? "2026-summer",
  "2026-spring",
  shouldRequireApiData()
);
const site = Astro.site ?? new URL("https://anisonary.k-y.cc");
const isMockData = data.status === "ready" && Boolean(data.current?.isMockData || data.previous?.isMockData);
---

<BaseLayout image="/assets/anisonary-hero.webp" jsonLd={buildWebsiteJsonLd(site)}>
  <section class="hero page-shell">
    <div class="hero__copy">
      <h1>按季度與動畫，<br /><span class="hero-title-line">找到每一首 <span>OP／ED</span> 的官方入口。</span></h1>
      <p>以日本播出日整理動畫與主題曲，連接官方影片、串流平台與資料來源。</p>
      <div class="hero__actions">
        <a class="button button--primary" href="/seasons/2026-summer/">
          瀏覽 2026 夏季
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M14 7l5 5-5 5" /></svg>
        </a>
        <a class="button button--outline" href="/seasons/2026-spring/">
          查看 2026 春季
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M14 7l5 5-5 5" /></svg>
        </a>
      </div>
      {isMockData ? <MockNotice /> : <CatalogStatus />}
    </div>
    <div class="hero__visual">
      <img src="/assets/anisonary-hero.webp" alt="唱片從歌典中展開，樂譜連接至日本鐵路月台的原創插畫" width="1200" height="800" decoding="async" />
    </div>
  </section>

  {data.status === "error" ? (
    <div class="page-shell">
      <ErrorState
        message="季度與動畫資料暫時無法取得。網站其他說明頁仍可正常瀏覽，請稍後重新載入。"
      />
    </div>
  ) : (
    <>
      <section class="season-preview page-shell" aria-labelledby="current-season-title">
        <div class="section-heading">
          <h2 id="current-season-title">2026 夏季動畫</h2>
          <a href="/seasons/2026-summer/">查看全部 2026 夏季動畫 <span aria-hidden="true">→</span></a>
        </div>
        {data.current ? (
          <div class="home-poster-grid">
            {data.current.anime.slice(0, 4).map((anime, index) => <AnimeCard anime={anime} eager={index < 2} variant="home" />)}
          </div>
        ) : (
          <p class="state-message">目前沒有可顯示的季度資料。</p>
        )}
      </section>

      <section class="previous-season page-shell" aria-labelledby="previous-season-title">
        <div class="section-heading section-heading--small">
          <div>
            <h2 id="previous-season-title">2026 春季動畫</h2>
            <p lang="ja">2026年春アニメ</p>
          </div>
          <a href="/seasons/2026-spring/">查看季度 <span aria-hidden="true">→</span></a>
        </div>
        {data.previous ? (
          <div class="previous-season__list">
            {data.previous.anime.slice(0, 4).map((anime) => (
              <a href={`/anime/${anime.slug}/`}>
                <PosterImage
                  src={anime.posterUrl}
                  alt=""
                  width={768}
                  height={1152}
                  className="previous-season__poster"
                  decorative
                />
                <span><strong lang="ja">{anime.titleJa}</strong><small>{anime.titleZhHant}</small></span>
              </a>
            ))}
          </div>
        ) : (
          <p class="state-message">上一季度資料尚未提供。</p>
        )}
      </section>

      <p class="sr-only">可用季度：{data.seasons.map((season) => season.titleZhHant).join("、")}</p>
    </>
  )}
</BaseLayout>

<style>
  .hero {
    align-items: center;
    display: grid;
    gap: clamp(2rem, 4vw, 3.5rem);
    grid-template-columns: minmax(0, 1.15fr) minmax(25rem, 0.85fr);
    padding-block: 3rem 1.5rem;
  }

  .hero h1 {
    font-size: clamp(2.4rem, 3vw, 2.8rem);
    letter-spacing: -0.05em;
    line-height: 1.14;
    margin: 0;
    max-width: 13.2em;
  }

  .hero h1 span { white-space: nowrap; }

  .hero__copy > p {
    color: var(--color-muted);
    font-size: clamp(1rem, 1.5vw, 1.17rem);
    line-height: 1.85;
    margin: 1.55rem 0 0;
    max-width: 35rem;
  }

  .hero__actions { display: flex; flex-wrap: wrap; gap: 0.85rem; margin-top: 2rem; }
  .hero__actions svg { fill: none; height: 1rem; stroke: currentColor; stroke-linecap: round; stroke-linejoin: round; stroke-width: 1.8; width: 1rem; }
  .hero__visual img { height: auto; mix-blend-mode: multiply; width: 100%; }
  :global([data-theme="dark"]) .hero__visual { background: #fbfcff; border-radius: 12px; overflow: hidden; }

  .season-preview { padding-top: 1rem; }
  .section-heading { align-items: baseline; border-bottom: 1px solid var(--color-border-strong); display: flex; gap: 2rem; justify-content: space-between; margin-bottom: 1.35rem; }
  .section-heading h2 { font-size: clamp(1.6rem, 2.8vw, 2.2rem); margin: 0; padding-bottom: 0.75rem; }
  .section-heading a { color: var(--color-ink); font-size: 0.82rem; font-weight: 720; text-decoration: none; }
  .section-heading a:hover { color: var(--color-accent); }
  .home-poster-grid { display: grid; gap: clamp(0.8rem, 1.6vw, 1.35rem); grid-template-columns: repeat(2, minmax(0, 1fr)); }

  .previous-season { background: var(--color-subtle); border: 1px solid var(--color-border); border-radius: var(--radius-card); margin-top: 2.5rem; padding-block: 1rem 1.3rem; }
  .section-heading--small { margin-bottom: 1rem; }
  .section-heading--small h2 { font-size: 1.45rem; padding-bottom: 0; }
  .section-heading--small p { color: var(--color-muted); font-size: 0.72rem; margin: 0.12rem 0 0; }
  .previous-season__list { display: grid; gap: 1rem; grid-template-columns: repeat(4, minmax(0, 1fr)); }
  .previous-season__list a { align-items: center; border-right: 1px solid var(--color-border); color: inherit; display: grid; gap: 0.7rem; grid-template-columns: 4rem 1fr; min-width: 0; padding-right: 1rem; text-decoration: none; }
  .previous-season__list a:last-child { border: 0; }
  :global(.previous-season__poster) { aspect-ratio: 1; border-radius: 5px; height: 4rem; width: 4rem; }
  .previous-season__list span { display: grid; min-width: 0; }
  .previous-season__list strong, .previous-season__list small { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .previous-season__list strong { font-size: 0.78rem; }
  .previous-season__list small { color: var(--color-muted); font-size: 0.68rem; margin-top: 0.25rem; }

  @media (max-width: 1100px) {
    .hero { grid-template-columns: 1fr 1fr; }
    .previous-season__list { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .previous-season__list a:nth-child(2) { border: 0; }
  }

  @media (max-width: 760px) {
    .hero { grid-template-columns: 1fr; min-height: 0; padding-block: 3.5rem; }
    .hero__visual { grid-row: 1; }
    .hero__visual img { max-height: 20rem; object-fit: contain; }
    .hero h1 br { display: none; }
    .hero h1 .hero-title-line { white-space: normal; }
    .section-heading { align-items: flex-start; flex-direction: column; gap: 0; }
    .section-heading a { padding-bottom: 0.8rem; }
    .home-poster-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .previous-season__list { grid-template-columns: 1fr; }
    .previous-season__list a { border-bottom: 1px solid var(--color-border); border-right: 0; padding-bottom: 1rem; }
  }

  @media (max-width: 560px) {
    .home-poster-grid { grid-template-columns: 1fr; }
  }
</style>
