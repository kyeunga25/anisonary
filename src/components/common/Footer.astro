---
import Logo from "@/components/common/Logo.astro";
---

<footer class="site-footer">
  <div class="site-footer__inner page-shell">
    <Logo compact />
    <nav aria-label="頁尾導覽">
      <a href="/about/">關於</a>
      <a href="/sources/">資料來源</a>
    </nav>
    <p>不託管音樂或影片，只連接官方與正版渠道。</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: clamp(4rem, 8vw, 7rem);
  }

  .site-footer__inner {
    align-items: center;
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr auto 1fr;
    min-height: 7rem;
  }

  .site-footer nav { display: flex; gap: 2rem; }
  .site-footer a { color: var(--color-muted); text-decoration: none; }
  .site-footer a:hover { color: var(--color-accent); }
  .site-footer p { color: var(--color-muted); font-size: 0.82rem; justify-self: end; margin: 0; text-align: right; }

  @media (max-width: 720px) {
    .site-footer__inner {
      align-items: start;
      grid-template-columns: 1fr;
      padding-block: 2.2rem;
    }

    .site-footer p { justify-self: start; text-align: left; }
  }
</style>
