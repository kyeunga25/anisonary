---
interface Props { compact?: boolean; }
const { compact = false } = Astro.props;
---

<aside class:list={["catalog-status", { "catalog-status--compact": compact }]} aria-label="季度資料狀態">
  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 12 4 4L19 6" /><circle cx="12" cy="12" r="10" /></svg>
  <p>
    <strong>已核對季度目錄</strong>
    <span>資料依日本官方頁面整理，繁中名稱另作交叉確認；最後核對 2026-07-24。</span>
  </p>
  {!compact && <a href="/sources/">檢視來源準則 <span aria-hidden="true">→</span></a>}
</aside>

<style>
  .catalog-status {
    align-items: center;
    background: color-mix(in srgb, var(--color-accent) 6%, var(--color-surface));
    border: 1px solid color-mix(in srgb, var(--color-accent) 30%, var(--color-border));
    border-radius: var(--radius-control);
    display: grid;
    gap: 0.7rem;
    grid-template-columns: auto 1fr auto;
    margin-top: 1.4rem;
    max-width: 44rem;
    padding: 0.85rem 1rem;
  }

  .catalog-status > svg { fill: none; height: 1.35rem; stroke: var(--color-accent); stroke-width: 1.8; width: 1.35rem; }
  .catalog-status p { display: grid; margin: 0; }
  .catalog-status strong { font-size: 0.82rem; }
  .catalog-status p span { color: var(--color-muted); font-size: 0.72rem; line-height: 1.55; }
  .catalog-status > a { color: var(--color-accent); font-size: 0.75rem; font-weight: 720; text-decoration: none; white-space: nowrap; }
  .catalog-status > a:hover { text-decoration: underline; text-underline-offset: 0.2em; }
  .catalog-status--compact { display: inline-grid; grid-template-columns: auto 1fr; margin-top: 1rem; }

  @media (max-width: 620px) {
    .catalog-status { grid-template-columns: auto 1fr; }
    .catalog-status > a { grid-column: 2; }
  }
</style>
