---
import Logo from "@/components/common/Logo.astro";
import ThemeToggle from "@/components/common/ThemeToggle.astro";

const pathname = Astro.url.pathname;
const links = [
  { href: "/", label: "首頁" },
  { href: "/seasons/2026-summer/", label: "2026 夏季" },
  { href: "/seasons/2026-spring/", label: "2026 春季" },
  { href: "/about/", label: "關於" },
  { href: "/sources/", label: "資料來源" }
];

const isActive = (href: string) => href === "/" ? pathname === "/" : pathname.startsWith(href.replace(/\/$/, ""));
---

<header class="site-header">
  <div class="site-header__inner page-shell">
    <Logo />
    <nav class="site-nav" aria-label="主要導覽">
      {links.map((link) => (
        <a href={link.href} aria-current={isActive(link.href) ? "page" : undefined}>{link.label}</a>
      ))}
    </nav>
    <ThemeToggle />
  </div>
</header>

<style>
  .site-header {
    background: color-mix(in srgb, var(--color-canvas) 94%, transparent);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(14px);
  }

  .site-header__inner {
    align-items: center;
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr auto 1fr;
    min-height: 5.35rem;
  }

  .site-nav {
    align-items: stretch;
    display: flex;
    gap: clamp(1.2rem, 3vw, 3.25rem);
    height: 5.35rem;
  }

  .site-nav a {
    align-items: center;
    color: var(--color-ink);
    display: flex;
    font-size: 0.94rem;
    font-weight: 680;
    position: relative;
    text-decoration: none;
  }

  .site-nav a::after {
    background: var(--color-accent);
    bottom: 0;
    content: "";
    height: 2px;
    left: 0;
    position: absolute;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 160ms ease;
    width: 100%;
  }

  .site-nav a:hover::after,
  .site-nav a[aria-current="page"]::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .site-nav a[aria-current="page"] { color: var(--color-accent); }
  .site-header :global(.theme-toggle) { justify-self: end; }

  @media (max-width: 880px) {
    .site-header__inner {
      grid-template-columns: 1fr auto;
      gap: 0.75rem;
      padding-block: 0.8rem 0;
    }

    .site-nav {
      grid-column: 1 / -1;
      grid-row: 2;
      height: auto;
      margin-inline: calc(var(--page-gutter) * -1);
      overflow-x: auto;
      padding-inline: var(--page-gutter);
      scrollbar-width: none;
    }

    .site-nav a {
      min-height: 2.8rem;
      white-space: nowrap;
    }
  }

  @media (max-width: 560px) {
    .site-nav {
      flex-wrap: wrap;
      gap: 0 0.9rem;
      justify-content: space-between;
      margin-inline: 0;
      overflow-x: visible;
      padding-inline: 0;
    }

    .site-nav a {
      font-size: 0.8rem;
      min-height: 2.55rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-nav a::after { transition: none; }
  }
</style>
