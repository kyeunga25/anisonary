---
interface Props { seasonId: string; seasonLabel: string; }
const { seasonId, seasonLabel } = Astro.props;
---

<div class="theme-empty" role="status">
  <svg viewBox="0 0 112 88" aria-hidden="true">
    <path d="M10 18c18-4 31 1 45 10v50C41 69 28 64 10 68V18Z" />
    <path d="M102 18c-18-4-31 1-45 10v50c14-9 27-14 45-10V18Z" />
    <path d="M55 28v50M26 33h18M26 43h18M68 33h18M68 43h18M49 69l7 7 7-7" />
    <path class="theme-empty__note" d="M80 5v18M80 5l13-3v18M80 23c-7-2-11 1-10 5 1 3 8 3 10-1M93 20c-7-2-11 1-10 5 1 3 8 3 10-1" />
  </svg>
  <div>
    <h3>主題曲資料尚未公布</h3>
    <p>OP／ED 公開後會在這裡整理歌曲、演唱者與官方資料來源。</p>
    <a href={`/seasons/${seasonId}/`}>← 返回 {seasonLabel}</a>
  </div>
</div>

<style>
  .theme-empty { align-items: center; border: 1px solid var(--color-border-strong); border-radius: var(--radius-card); display: flex; gap: clamp(1.5rem, 4vw, 4.5rem); padding: clamp(1.6rem, 4vw, 3.4rem); }
  .theme-empty > svg { fill: none; flex: 0 0 clamp(7rem, 16vw, 10rem); stroke: var(--color-ink); stroke-linecap: round; stroke-linejoin: round; stroke-width: 1.8; }
  .theme-empty__note { stroke: var(--color-accent); }
  .theme-empty h3 { font-size: clamp(1.4rem, 3vw, 2rem); margin: 0; }
  .theme-empty p { color: var(--color-muted); line-height: 1.7; margin: 0.65rem 0 1.2rem; }
  .theme-empty a { color: var(--color-ink); font-weight: 720; text-underline-offset: 0.25em; }
  .theme-empty a:hover { color: var(--color-accent); }
  @media (max-width: 560px) { .theme-empty { align-items: flex-start; flex-direction: column; } }
</style>
