---
import AnimeCard from "@/components/anime/AnimeCard.astro";
import type { PublicAnimeCard } from "@/types/public-api";
import { editorialWeekdays, groupByEditorialWeekday, irregularWeekday } from "@/utils/weekday";

interface Props { anime: PublicAnimeCard[]; }
const { anime } = Astro.props;
const groups = groupByEditorialWeekday(anime);
const navigation = [...editorialWeekdays, irregularWeekday];
---

<div class="season-tools" data-season-directory>
  <div class="season-filters" role="group" aria-label="篩選動畫">
    <label><input type="checkbox" data-filter="op" /><span>有 OP</span></label>
    <label><input type="checkbox" data-filter="ed" /><span>有 ED</span></label>
    <label><input type="checkbox" data-filter="video" /><span>有官方影片</span></label>
    <button type="button" data-clear-filters>清除篩選</button>
    <p aria-live="polite"><strong data-result-count>{anime.length}</strong> 套動畫</p>
  </div>

  <nav class="weekday-nav" aria-label="跳到播出星期">
    {navigation.map((day, index) => (
      <a href={`#weekday-${day.value || "irregular"}`} aria-current={index === 0 ? "location" : undefined}>{day.shortLabel}</a>
    ))}
  </nav>

  <p class="filter-empty" data-filter-empty hidden>沒有符合目前篩選條件的動畫。</p>

  <div class="weekday-sections">
    {navigation.map((day) => {
      const key = day.value === 0 ? "irregular" : `${day.value}` as `${1 | 2 | 3 | 4 | 5 | 6 | 7}`;
      const items = groups.get(key) ?? [];
      return (
        <section class="weekday-section" id={`weekday-${day.value || "irregular"}`} data-weekday-section>
          <div class="weekday-section__heading">
            <h2>{day.sectionLabel}</h2>
            <span>{items.length} 套</span>
          </div>
          {items.length ? (
            <div class="poster-grid">
              {items.map((item, index) => <AnimeCard anime={item} eager={day.value === 1 && index < 5} variant="directory" />)}
            </div>
          ) : (
            <p class="weekday-section__empty">目前沒有已公開的 Mock 動畫資料。</p>
          )}
        </section>
      );
    })}
  </div>
</div>

<script>
  const directory = document.querySelector<HTMLElement>("[data-season-directory]");

  if (directory) {
    const filters = Array.from(directory.querySelectorAll<HTMLInputElement>("[data-filter]"));
    const cards = Array.from(directory.querySelectorAll<HTMLElement>("[data-anime-card]"));
    const sections = Array.from(directory.querySelectorAll<HTMLElement>("[data-weekday-section]"));
    const count = directory.querySelector<HTMLElement>("[data-result-count]");
    const empty = directory.querySelector<HTMLElement>("[data-filter-empty]");
    const clear = directory.querySelector<HTMLButtonElement>("[data-clear-filters]");

    const applyFilters = () => {
      const active = new Set(filters.filter((filter) => filter.checked).map((filter) => filter.dataset.filter));
      let visible = 0;

      cards.forEach((card) => {
        const show =
          (!active.has("op") || card.dataset.hasOp === "true") &&
          (!active.has("ed") || card.dataset.hasEd === "true") &&
          (!active.has("video") || card.dataset.hasVideo === "true");
        card.hidden = !show;
        if (show) visible += 1;
      });

      sections.forEach((section) => {
        const sectionCards = Array.from(section.querySelectorAll<HTMLElement>("[data-anime-card]"));
        section.hidden = sectionCards.length > 0 && sectionCards.every((card) => card.hidden);
      });

      if (count) count.textContent = String(visible);
      if (empty) empty.hidden = visible !== 0;
    };

    filters.forEach((filter) => filter.addEventListener("change", applyFilters));
    clear?.addEventListener("click", () => {
      filters.forEach((filter) => { filter.checked = false; });
      applyFilters();
      filters[0]?.focus();
    });
  }
</script>

<style>
  .season-tools { margin-top: 2.2rem; }

  .season-filters {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .season-filters label {
    align-items: center;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-control);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.82rem;
    font-weight: 650;
    gap: 0.5rem;
    min-height: 2.65rem;
    padding: 0.45rem 0.8rem;
  }

  .season-filters label:has(input:checked) { border-color: var(--color-ink); color: var(--color-ink); }
  .season-filters input { accent-color: var(--color-ink); height: 1rem; width: 1rem; }
  .season-filters button { background: transparent; border: 0; color: var(--color-accent); cursor: pointer; font: inherit; font-size: 0.82rem; font-weight: 680; padding: 0.6rem; }
  .season-filters p { color: var(--color-muted); font-size: 0.78rem; margin: 0 0 0 auto; }
  .season-filters p strong { color: var(--color-ink); }

  .weekday-nav {
    border-bottom: 1px solid var(--color-border-strong);
    display: flex;
    gap: clamp(1.7rem, 5vw, 5rem);
    margin-top: 1.4rem;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .weekday-nav a {
    color: var(--color-ink);
    flex: none;
    font-size: 0.88rem;
    font-weight: 720;
    padding: 0.85rem 0;
    position: relative;
    text-decoration: none;
  }

  .weekday-nav a:first-child::after {
    background: var(--color-accent);
    bottom: -1px;
    content: "";
    height: 3px;
    left: 0;
    position: absolute;
    width: 100%;
  }

  .filter-empty { border: 1px solid var(--color-border); color: var(--color-muted); margin: 2rem 0; padding: 1.4rem; text-align: center; }
  .weekday-section { scroll-margin-top: 9.5rem; }
  .weekday-section + .weekday-section { margin-top: 3.3rem; }

  .weekday-section__heading {
    align-items: baseline;
    border-bottom: 1px solid var(--color-border-strong);
    display: flex;
    justify-content: space-between;
    margin-bottom: 1rem;
    padding-top: 2rem;
  }

  .weekday-section__heading h2 { font-size: clamp(1.25rem, 2.2vw, 1.65rem); margin: 0; padding-bottom: 0.7rem; position: relative; }
  .weekday-section__heading h2::after { background: var(--color-accent); bottom: -1px; content: ""; height: 3px; left: 0; position: absolute; width: 3.5rem; }
  .weekday-section__heading span { color: var(--color-muted); font-size: 0.74rem; }

  .poster-grid { display: grid; gap: clamp(0.75rem, 1.5vw, 1.2rem); grid-template-columns: repeat(5, minmax(0, 1fr)); }
  .weekday-section__empty { color: var(--color-muted); font-size: 0.88rem; margin: 1.8rem 0; }

  @media (max-width: 1040px) {
    .poster-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  }

  @media (max-width: 760px) {
    .poster-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .season-filters p { width: 100%; }
    .weekday-nav { margin-inline: calc(var(--page-gutter) * -1); padding-inline: var(--page-gutter); }
  }
</style>
