---
import type { PublicAnimeDetail } from "@/types/public-api";

interface Props { sources: PublicAnimeDetail["sources"]; }
const { sources } = Astro.props;
---

<ul class="source-list">
  {sources.map((source) => (
    <li>
      <a href={source.url} target="_blank" rel="noopener noreferrer external">
        <span class="source-list__label">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 3h9l4 4v14H6zM14 3v5h5M9 13h7M9 17h7" /></svg>
          {source.label}
        </span>
        <span class="source-list__verified">最後驗證：{source.verifiedAt ?? "待確認"}</span>
        <span aria-hidden="true">↗</span>
        <span class="sr-only">（在新分頁開啟外部網站）</span>
      </a>
    </li>
  ))}
</ul>

<style>
  .source-list { display: grid; gap: 0.55rem; list-style: none; margin: 0; padding: 0; }
  .source-list li { border: 1px solid var(--color-border-strong); border-radius: var(--radius-control); }
  .source-list a { align-items: center; color: var(--color-ink); display: grid; gap: 1rem; grid-template-columns: 1fr auto auto; min-height: 3.5rem; padding: 0.8rem 1.1rem; text-decoration: none; }
  .source-list a:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .source-list__label { align-items: center; display: flex; font-weight: 680; gap: 0.65rem; }
  .source-list svg { fill: none; height: 1.2rem; stroke: currentColor; stroke-width: 1.5; width: 1.2rem; }
  .source-list__verified { color: var(--color-muted); font-size: 0.78rem; }
  @media (max-width: 620px) {
    .source-list a { grid-template-columns: 1fr auto; }
    .source-list__verified { grid-column: 1 / -1; grid-row: 2; }
  }
</style>
