---
import type { PublicExternalLink } from "@/types/public-api";
import { externalLinkTypeLabel } from "@/utils/links";

interface Props { links: PublicExternalLink[]; }
const { links } = Astro.props;

function platformKey(platform: string): "apple" | "spotify" | "youtube" | "disc" | "generic" {
  const value = platform.toLowerCase();
  if (value.includes("apple")) return "apple";
  if (value.includes("spotify")) return "spotify";
  if (value.includes("youtube")) return "youtube";
  if (value.includes("cd") || value.includes("physical")) return "disc";
  return "generic";
}
---

<ul class="external-links" aria-label="音樂平台與購買連結">
  {links.map((link) => (
    <li>
      <a href={link.url} target="_blank" rel="noopener noreferrer external">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          {platformKey(link.platform) === "apple" && <><path d="M9 18V7l10-2v11" /><circle cx="6.5" cy="18" r="2.5" /><circle cx="16.5" cy="16" r="2.5" /></>}
          {platformKey(link.platform) === "spotify" && <><circle cx="12" cy="12" r="9" /><path d="M7 9.5c3.5-1 7.2-.7 10.5.8M7.8 13c3-0.7 6.2-.4 9 .8M8.8 16.1c2.3-.5 4.8-.2 6.9.7" /></>}
          {platformKey(link.platform) === "youtube" && <><circle cx="12" cy="12" r="9" /><path d="m10 8.7 5 3.3-5 3.3V8.7Z" /></>}
          {platformKey(link.platform) === "disc" && <><circle cx="12" cy="12" r="9" /><circle cx="12" cy="12" r="2.5" /><path d="M14 4.5 12 9" /></>}
          {platformKey(link.platform) === "generic" && <><path d="M10 14 20 4M13 4h7v7" /><path d="M18 13v6H5V6h6" /></>}
        </svg>
        <span>{link.platform} · {externalLinkTypeLabel(link.linkType)}</span>
        <span class="sr-only">（在新分頁開啟外部網站）</span>
        <svg class="external-links__arrow" viewBox="0 0 20 20" aria-hidden="true"><path d="M7 4h9v9M16 4 4 16" /></svg>
      </a>
    </li>
  ))}
</ul>

<style>
  .external-links { border: 1px solid var(--color-border-strong); border-radius: var(--radius-control); display: grid; grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr)); list-style: none; margin: 0; padding: 0; }
  .external-links li + li { border-left: 1px solid var(--color-border); }
  .external-links a { align-items: center; color: var(--color-ink); display: flex; font-size: 0.82rem; font-weight: 670; gap: 0.65rem; justify-content: center; min-height: 3.75rem; padding: 0.8rem 1rem; text-decoration: none; }
  .external-links a:hover { color: var(--color-accent); }
  .external-links svg { fill: none; flex: 0 0 auto; height: 1.3rem; stroke: currentColor; stroke-linecap: round; stroke-linejoin: round; stroke-width: 1.55; width: 1.3rem; }
  .external-links__arrow { height: 0.9rem !important; width: 0.9rem !important; }

  @media (max-width: 720px) {
    .external-links { grid-template-columns: 1fr; }
    .external-links li + li { border-left: 0; border-top: 1px solid var(--color-border); }
    .external-links a { justify-content: flex-start; }
  }
</style>
